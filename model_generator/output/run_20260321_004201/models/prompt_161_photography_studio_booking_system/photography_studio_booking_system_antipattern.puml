@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor Customer
actor Photographer
actor "Studio Manager" as Manager
actor "Payment Gateway" as Gateway

rectangle "Photography Studio Booking System" {
  usecase "Register Customer" as UC1
  usecase "Send Confirmation Email" as UC2
  usecase "Browse Studio Packages" as UC3
  usecase "Book Studio Session" as UC4
  usecase "Validate Time Slot Availability" as UC5
  usecase "Cancel Booking" as UC6
  usecase "Process Payment" as UC7
  usecase "Generate Payment Receipt" as UC8
  usecase "View Booking Schedule" as UC9
  usecase "Upload Portfolio" as UC10
  usecase "Manage Studio Rooms" as UC11
  usecase "Generate Revenue Report" as UC12
  usecase "Apply Discount" as UC13
}

Customer -- UC1
Customer -- UC3
Customer -- UC4
Customer -- UC6
Customer -- UC7

Photographer -- UC9
Photographer -- UC10

Manager -- UC11
Manager -- UC12
Manager -- UC9

Gateway -- UC7

UC1 ..> UC2 : <<include>>
UC4 ..> UC5 : <<include>>
UC7 ..> UC8 : <<include>>
UC7 ..> UC4 : <<extend>>
UC13 ..> UC7 : <<extend>>

@enduml