@startuml
' Version 2 – refactored, no antipattern (Drop Functional Decomposition)

actor "System Administrator" as Admin
actor "Homeowner" as Owner

rectangle "Solar Energy Management System" {
  usecase "Configure Solar Panels" as UC1
  usecase "Monitor Energy Production" as UC2
  usecase "View Energy Reports" as UC3
  usecase "Manage Battery Storage" as UC4
}

Admin -- UC1
Admin -- UC4
Owner -- UC2
Owner -- UC3

@enduml