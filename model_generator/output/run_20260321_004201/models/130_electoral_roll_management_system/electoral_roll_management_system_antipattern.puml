@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "Election Officer" as EO
actor "Voter" as V
actor "System Administrator" as SA

rectangle "Electoral Roll Management System" {
  usecase "Register Voter" as UC1
  usecase "Validate ID Documents" as UC1a
  usecase "Update Voter Record" as UC2
  usecase "Verify Address Change" as UC2a
  usecase "Remove Voter" as UC3
  usecase "Confirm Removal Eligibility" as UC3a
  usecase "Search Electoral Roll" as UC4
  usecase "Generate Voter List" as UC5
  usecase "View Registration Status" as UC6
  usecase "Submit Registration Application" as UC7
  usecase "Manage Polling Districts" as UC8
  usecase "Audit Electoral Roll" as UC9
  usecase "Export Roll Data" as UC10
  usecase "Manage User Accounts" as UC11
}

EO -- UC1
EO -- UC2
EO -- UC3
EO -- UC4
EO -- UC5
EO -- UC9

V -- UC6
V -- UC7

SA -- UC8
SA -- UC10
SA -- UC11

UC1 ..> UC1a : <<include>>
UC2 ..> UC2a : <<include>>
UC3 ..> UC3a : <<include>>
@enduml