@startuml
' Version 2 – refactored, no antipattern (Drop Functional Decomposition)

actor "Attendee" as A1
actor "Organizer" as A2
actor "Speaker" as A3

rectangle "Conference Registration System" {
  usecase "Browse Conference Schedule" as UC1
  usecase "Register for Conference" as UC2
  usecase "Submit Paper Abstract" as UC3
  usecase "Manage Registrations" as UC4
  usecase "Cancel Registration" as UC6
}

A1 -- UC1
A1 -- UC2
A3 -- UC3
A2 -- UC4
A1 -- UC6
@enduml