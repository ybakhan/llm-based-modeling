@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "Company Applicant" as Applicant
actor "Registrar" as Registrar
actor "Company Director" as Director
actor "System Administrator" as Admin

rectangle "Company Registration System" {
  usecase "Register New Company" as UC1
  usecase "Validate Company Name" as UC2
  usecase "Generate Registration Number" as UC3
  usecase "Search Company Registry" as UC4
  usecase "Submit Annual Return" as UC5
  usecase "Calculate Filing Fee" as UC6
  usecase "Update Company Details" as UC7
  usecase "Dissolve Company" as UC8
  usecase "Review Registration Application" as UC9
  usecase "Process Payment" as UC10
  usecase "Generate Compliance Report" as UC11
  usecase "Manage User Accounts" as UC12
  usecase "File Director Changes" as UC13
  usecase "Request Company Certificate" as UC14
}

Applicant -- UC1
Applicant -- UC4
Applicant -- UC10
Director -- UC5
Director -- UC7
Director -- UC13
Director -- UC14
Registrar -- UC9
Registrar -- UC8
Registrar -- UC11
Admin -- UC12

UC1 ..> UC2 : <<include>>
UC1 ..> UC3 : <<include>>
UC5 ..> UC6 : <<include>>

UC8 ..> UC9 : <<extend>>
}
@enduml