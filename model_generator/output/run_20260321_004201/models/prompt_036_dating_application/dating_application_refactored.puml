@startuml
' Version 2 – refactored, no antipattern (Drop Functional Decomposition)
left to right direction

actor "User" as A1
actor "Admin" as A2

rectangle "Dating Application" {
  usecase "Browse Profiles" as UC1
  usecase "Create Profile" as UC2
  usecase "Send Message" as UC3
  usecase "Manage Reports" as UC4
  usecase "Swipe Match" as UC6
}

A1 -- UC1
A1 -- UC2
A1 -- UC3
A1 -- UC6
A2 -- UC4
@enduml