@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "Student" as Student
actor "Registrar" as Registrar
actor "Financial Officer" as FinOfficer
actor "Advisor" as Advisor

rectangle "University Enrollment System" {
  usecase "Submit Application" as UC1
  usecase "Verify Application Data" as UC2
  usecase "Register for Course" as UC3
  usecase "Validate Prerequisites" as UC4
  usecase "Drop Course" as UC5
  usecase "View Enrollment Status" as UC6
  usecase "Process Tuition Payment" as UC7
  usecase "Calculate Tuition Fees" as UC8
  usecase "Review Applications" as UC9
  usecase "Generate Enrollment Report" as UC10
  usecase "Approve Course Override" as UC11
  usecase "View Academic Schedule" as UC12
  usecase "Apply for Financial Aid" as UC13
  usecase "Request Transcript" as UC14
}

Student -- UC1
Student -- UC3
Student -- UC5
Student -- UC6
Student -- UC7
Student -- UC12
Student -- UC13
Student -- UC14

Registrar -- UC9
Registrar -- UC10

FinOfficer -- UC7

Advisor -- UC11

UC1 ..> UC2 : <<include>>
UC3 ..> UC4 : <<include>>
UC7 ..> UC8 : <<include>>

@enduml