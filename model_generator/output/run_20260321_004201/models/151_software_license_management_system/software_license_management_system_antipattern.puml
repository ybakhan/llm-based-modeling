@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "License Administrator" as Admin
actor "End User" as EndUser
actor "Compliance Auditor" as Auditor
actor "Vendor" as Vendor

rectangle "Software License Management System" {
  usecase "Purchase License" as UC1
  usecase "Validate Payment Details" as UC2
  usecase "Renew License" as UC3
  usecase "Assign License to User" as UC4
  usecase "Check License Availability" as UC5
  usecase "Revoke License" as UC6
  usecase "View Assigned Licenses" as UC7
  usecase "Request License" as UC8
  usecase "Generate Compliance Report" as UC9
  usecase "Fetch License Data" as UC10
  usecase "Monitor License Expiry" as UC11
  usecase "Manage License Keys" as UC12
  usecase "View License Catalog" as UC13
  usecase "Notify Expiring Licenses" as UC14
}

Admin -- UC1
Admin -- UC3
Admin -- UC4
Admin -- UC6
Admin -- UC11
Admin -- UC12

EndUser -- UC7
EndUser -- UC8
EndUser -- UC13

Auditor -- UC9

Vendor -- UC1

UC1 ..> UC2 : <<include>>
UC9 ..> UC10 : <<include>>
UC4 ..> UC5 : <<include>>

UC11 ..> UC14 : <<include>>
UC3 ..> UC14 : <<extend>>

@enduml