@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor Customer
actor Staff

rectangle "Sports Equipment Rental System" {
  usecase "Browse Catalog" as UC1
  usecase "Search Inventory" as UC2
  usecase "Rent Equipment" as UC3
  usecase "Verify Availability" as UC4
  usecase "Return Equipment" as UC5
  usecase "Process Payment" as UC6
  usecase "Validate Payment Details" as UC7
  usecase "Apply Late Fee" as UC8
  usecase "Manage Inventory" as UC9
  usecase "View Rental History" as UC10
  usecase "Register Account" as UC11
}

Customer -- UC1
Customer -- UC3
Customer -- UC5
Customer -- UC6
Customer -- UC10
Customer -- UC11
Staff -- UC9
Staff -- UC5

UC1 ..> UC2 : <<include>>
UC3 ..> UC4 : <<include>>
UC6 ..> UC7 : <<include>>
UC5 <.. UC8 : <<extend>>

@enduml