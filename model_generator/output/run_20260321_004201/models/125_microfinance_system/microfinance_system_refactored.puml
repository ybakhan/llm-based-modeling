@startuml
' Version 2 – refactored, no antipattern (Drop Functional Decomposition)
left to right direction
skinparam packageStyle rectangle

actor "Loan Officer" as LO
actor "Branch Manager" as BM
actor "Borrower" as BO
actor "Auditor" as AU

rectangle "Microfinance System" {
  usecase "Process Loan Application" as UC1
  usecase "Disburse Loan" as UC3
  usecase "Manage Repayments" as UC5
  usecase "Register Borrower" as UC7
  usecase "View Loan Status" as UC8
  usecase "Generate Financial Report" as UC9
  usecase "Approve Loan" as UC10
  usecase "Close Loan Account" as UC11
  usecase "Record Savings Deposit" as UC12
}

LO -- UC1
LO -- UC3
LO -- UC5
LO -- UC7
LO -- UC12
BO -- UC8
BM -- UC10
BM -- UC9
BM -- UC11
AU -- UC9
@enduml