@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship
left to right direction

actor "Reader" as Reader
actor "Author" as Author

rectangle "Graphic Novel Platform" {
  usecase "Browse Catalog" as UC1
  usecase "Read Novel" as UC2
  usecase "Rate Novel" as UC3
  usecase "Upload Novel" as UC4
  usecase "Manage Chapters" as UC5
  usecase "Load Thumbnail Previews" as UC6
  usecase "Search Novels" as UC7
}

Reader -- UC1
Reader -- UC2
Reader -- UC3
Reader -- UC7
Author -- UC4
Author -- UC5

UC1 ..> UC6 : <<include>>
@enduml