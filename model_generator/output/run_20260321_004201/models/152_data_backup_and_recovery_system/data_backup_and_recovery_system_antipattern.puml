@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "System Administrator" as Admin
actor "End User" as User
actor "Monitoring Service" as Monitor

rectangle "Data Backup and Recovery System" {
  usecase "Schedule Backup" as UC1
  usecase "Validate Backup Schedule" as UC2
  usecase "Perform Full Backup" as UC3
  usecase "Compress Backup Data" as UC4
  usecase "Perform Incremental Backup" as UC5
  usecase "Restore Data" as UC6
  usecase "Verify Data Integrity" as UC7
  usecase "View Backup History" as UC8
  usecase "Configure Retention Policy" as UC9
  usecase "Monitor Backup Status" as UC10
  usecase "Generate Backup Report" as UC11
  usecase "Manage Storage Locations" as UC12
  usecase "Request File Recovery" as UC13
}

Admin -- UC1
Admin -- UC3
Admin -- UC5
Admin -- UC9
Admin -- UC12
Admin -- UC6

User -- UC8
User -- UC13

Monitor -- UC10
Monitor -- UC11

UC1 ..> UC2 : <<include>>
UC3 ..> UC4 : <<include>>
UC6 ..> UC7 : <<include>>

UC13 ..> UC6 : <<include>>
UC10 .> UC11 : <<extend>>

@enduml