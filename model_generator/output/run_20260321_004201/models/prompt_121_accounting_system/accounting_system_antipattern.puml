@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "Accountant" as Accountant
actor "Manager" as Manager
actor "Auditor" as Auditor
actor "Payroll Clerk" as PayrollClerk

rectangle "Accounting System" {
  usecase "Create Invoice" as UC1
  usecase "Validate Invoice Fields" as UC2
  usecase "Record Payment" as UC3
  usecase "Manage Chart of Accounts" as UC4
  usecase "Generate Financial Report" as UC5
  usecase "Fetch Report Data" as UC6
  usecase "Process Payroll" as UC7
  usecase "Calculate Deductions" as UC8
  usecase "Reconcile Bank Statements" as UC9
  usecase "Manage Tax Filing" as UC10
  usecase "Review Audit Trail" as UC11
  usecase "Approve Expense Claims" as UC12
  usecase "Record Journal Entry" as UC13
  usecase "Manage Vendor Accounts" as UC14
  usecase "Generate Tax Summary" as UC15
  usecase "Flag Discrepancy" as UC16
}

Accountant -- UC1
Accountant -- UC3
Accountant -- UC4
Accountant -- UC9
Accountant -- UC13
Accountant -- UC14

Manager -- UC5
Manager -- UC12
Manager -- UC10

PayrollClerk -- UC7

Auditor -- UC11
Auditor -- UC15

UC1 ..> UC2 : <<include>>
UC5 ..> UC6 : <<include>>
UC7 ..> UC8 : <<include>>
UC9 ..> UC16 : <<extend>>

@enduml