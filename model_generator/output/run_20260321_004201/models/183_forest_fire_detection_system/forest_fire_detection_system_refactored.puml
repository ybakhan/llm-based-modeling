@startuml
' Version 2 – refactored, no antipattern (Drop Functional Decomposition)

actor "Park Ranger" as Ranger
actor "Emergency Service" as Emergency

rectangle "Forest Fire Detection System" {
  usecase "Monitor Forest Area" as UC1
  usecase "Trigger Fire Alert" as UC3
  usecase "View Fire Reports" as UC4
  usecase "Dispatch Response Team" as UC5
}

Ranger -- UC1
Ranger -- UC4
Emergency -- UC3
Emergency -- UC5

@enduml