@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "Guest" as Guest
actor "Receptionist" as Receptionist
actor "Manager" as Manager

rectangle "Hotel Booking System" {
  usecase "Search Rooms" as UC1
  usecase "Make Reservation" as UC2
  usecase "Validate Room Availability" as UC3
  usecase "Cancel Reservation" as UC4
  usecase "Process Payment" as UC5
  usecase "Calculate Total Cost" as UC6
  usecase "Check In Guest" as UC7
  usecase "Verify Booking Details" as UC8
  usecase "Check Out Guest" as UC9
  usecase "View Booking History" as UC10
  usecase "Generate Occupancy Report" as UC11
  usecase "Manage Room Inventory" as UC12
  usecase "Apply Discount" as UC13
}

Guest -- UC1
Guest -- UC2
Guest -- UC4
Guest -- UC5
Guest -- UC10

Receptionist -- UC7
Receptionist -- UC9

Manager -- UC11
Manager -- UC12

UC2 ..> UC3 : <<include>>
UC5 ..> UC6 : <<include>>
UC7 ..> UC8 : <<include>>

UC5 ..> UC13 : <<extend>>

@enduml