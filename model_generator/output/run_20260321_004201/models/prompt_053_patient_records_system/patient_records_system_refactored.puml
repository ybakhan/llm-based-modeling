@startuml
' Version 2 – refactored, no antipattern (Drop Functional Decomposition)
left to right direction

actor "Doctor" as Doctor
actor "Receptionist" as Receptionist

rectangle "Patient Records System" {
  usecase "View Patient Record" as UC1
  usecase "Update Patient Record" as UC2
  usecase "Register Patient" as UC3
  usecase "Schedule Appointment" as UC5
  usecase "Search Patient" as UC6
}

Doctor -- UC1
Doctor -- UC2
Receptionist -- UC3
Receptionist -- UC5
Receptionist -- UC6
@enduml