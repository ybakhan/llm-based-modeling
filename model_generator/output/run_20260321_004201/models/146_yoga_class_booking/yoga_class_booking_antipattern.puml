@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "Member" as A1
actor "Instructor" as A2

rectangle "Yoga Class Booking System" {
  usecase "Browse Classes" as UC1
  usecase "Book Class" as UC2
  usecase "Cancel Booking" as UC3
  usecase "View My Schedule" as UC4
  usecase "Check Schedule Availability" as UC5
  usecase "Manage Class Offerings" as UC6
}

A1 -- UC1
A1 -- UC2
A1 -- UC3
A1 -- UC4
A2 -- UC6

UC2 ..> UC5 : <<include>>

@enduml