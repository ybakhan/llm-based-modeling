@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "Reporter" as Reporter
actor "Project Manager" as PM
actor "Developer" as Dev
actor "QA Tester" as QA

rectangle "Software Bug Tracking System" {
  usecase "Report Bug" as UC1
  usecase "Validate Bug Fields" as UC2
  usecase "View Bug List" as UC3
  usecase "Search Bugs" as UC4
  usecase "Assign Bug" as UC5
  usecase "Select Developer" as UC6
  usecase "Update Bug Status" as UC7
  usecase "Add Comment" as UC8
  usecase "Close Bug" as UC9
  usecase "Record Resolution Details" as UC10
  usecase "Reopen Bug" as UC11
  usecase "Generate Bug Report" as UC12
  usecase "Verify Fix" as UC13
  usecase "Set Bug Priority" as UC14
  usecase "Attach File" as UC15
}

Reporter -- UC1
Reporter -- UC3
Reporter -- UC4
Reporter -- UC11

PM -- UC5
PM -- UC12
PM -- UC14
PM -- UC3

Dev -- UC7
Dev -- UC8
Dev -- UC9
Dev -- UC15

QA -- UC13
QA -- UC3

UC1 ..> UC2 : <<include>>
UC5 ..> UC6 : <<include>>
UC9 ..> UC10 : <<include>>

UC1 ..> UC15 : <<extend>>

@enduml