@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "Student" as Student
actor "Instructor" as Instructor
actor "Administrator" as Admin
actor "Cashier" as Cashier

rectangle "Driving School Management System" {
  usecase "Register Student" as UC1
  usecase "Verify Student Documents" as UC2
  usecase "Schedule Driving Lesson" as UC3
  usecase "Check Instructor Availability" as UC4
  usecase "Record Lesson Outcome" as UC5
  usecase "Process Payment" as UC6
  usecase "Validate Payment Details" as UC7
  usecase "Take Theory Exam" as UC8
  usecase "Take Practical Exam" as UC9
  usecase "Manage Instructor Roster" as UC10
  usecase "Generate Progress Report" as UC11
  usecase "View Schedule" as UC12

  UC1 ..> UC2 : <<include>>
  UC3 ..> UC4 : <<include>>
  UC6 ..> UC7 : <<include>>
  UC8 ..> UC3 : <<extend>>
}

Admin -- UC1
Admin -- UC3
Admin -- UC10
Admin -- UC11
Instructor -- UC5
Instructor -- UC12
Student -- UC8
Student -- UC9
Student -- UC12
Cashier -- UC6

@enduml