@startuml
' Version 2 – refactored, no antipattern (Drop Functional Decomposition)
left to right direction

actor "Shopper" as Shopper
actor "Retailer" as Retailer
actor "Admin" as Admin

rectangle "Price Comparison Portal" {
  usecase "Search Products" as UC1
  usecase "Compare Prices" as UC3
  usecase "View Product Details" as UC5
  usecase "Filter Results" as UC6
  usecase "Set Price Alert" as UC7
  usecase "Write Review" as UC9
  usecase "Register Account" as UC10
  usecase "Manage Retailer Listings" as UC11
  usecase "View Price History" as UC12
  usecase "Moderate Reviews" as UC13
  usecase "Generate Analytics Report" as UC14
}

Shopper -- UC1
Shopper -- UC3
Shopper -- UC5
Shopper -- UC6
Shopper -- UC7
Shopper -- UC9
Shopper -- UC10
Shopper -- UC12
Retailer -- UC11
Retailer -- UC10
Admin -- UC13
Admin -- UC14
@enduml