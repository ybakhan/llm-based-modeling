@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "Trader" as Trader
actor "Broker" as Broker
actor "System Administrator" as Admin

rectangle "Stock Trading Platform" {
  usecase "Place Order" as UC1
  usecase "Validate Order Parameters" as UC2
  usecase "Execute Trade" as UC3
  usecase "Route to Exchange" as UC4
  usecase "View Portfolio" as UC5
  usecase "Fetch Account Data" as UC6
  usecase "Cancel Order" as UC7
  usecase "View Market Data" as UC8
  usecase "Set Price Alert" as UC9
  usecase "Manage User Accounts" as UC10
  usecase "Generate Trade Report" as UC11
  usecase "Place Limit Order" as UC12
  usecase "Place Market Order" as UC13

  UC1 ..> UC2 : <<include>>
  UC3 ..> UC4 : <<include>>
  UC5 ..> UC6 : <<include>>

  UC12 --|> UC1
  UC13 --|> UC1

  UC7 ..> UC1 : <<extend>>
}

Trader -- UC1
Trader -- UC5
Trader -- UC8
Trader -- UC9
Broker -- UC3
Broker -- UC11
Admin -- UC10

@enduml