@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor Customer
actor "Event Organizer" as Organizer

rectangle "Event Ticketing System" {
  usecase "Browse Events" as UC1
  usecase "Purchase Ticket" as UC2
  usecase "Validate Payment Details" as UC3
  usecase "Cancel Ticket" as UC4
  usecase "Create Event" as UC5
  usecase "View Sales Report" as UC6
}

Customer -- UC1
Customer -- UC2
UC2 ..> UC3 : <<include>>
Customer -- UC4
Organizer -- UC5
Organizer -- UC6

@enduml