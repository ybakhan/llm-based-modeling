@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship
left to right direction

actor "Applicant" as Applicant
actor "Loan Officer" as LoanOfficer
actor "Manager" as Manager
actor "Credit Bureau" as CreditBureau

rectangle "Loan Approval System" {
    usecase "Submit Loan Application" as UC1
    usecase "Validate Applicant Identity" as UC2
    usecase "Track Application Status" as UC3
    usecase "Evaluate Loan Application" as UC4
    usecase "Calculate Credit Score" as UC5
    usecase "Request Additional Documents" as UC6
    usecase "Approve Loan" as UC7
    usecase "Generate Loan Agreement" as UC8
    usecase "Reject Loan" as UC9
    usecase "Appeal Rejection" as UC10
    usecase "Override Decision" as UC11
    usecase "Retrieve Credit Report" as UC12
    usecase "Disburse Funds" as UC13
}

Applicant -- UC1
Applicant -- UC3
Applicant -- UC10

LoanOfficer -- UC4
LoanOfficer -- UC6
LoanOfficer -- UC7
LoanOfficer -- UC9
LoanOfficer -- UC13

Manager -- UC11

CreditBureau -- UC12

UC1 ..> UC2 : <<include>>
UC4 ..> UC5 : <<include>>
UC4 ..> UC12 : <<include>>
UC7 ..> UC8 : <<include>>
}
@enduml