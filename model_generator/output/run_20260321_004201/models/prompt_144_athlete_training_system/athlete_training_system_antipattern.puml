@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship
left to right direction

actor "Athlete" as Athlete
actor "Coach" as Coach
actor "Medical Staff" as MedicalStaff

rectangle "Athlete Training System" {
  usecase "Schedule Training Session" as UC1
  usecase "Validate Time Slot" as UC2
  usecase "Log Workout Results" as UC3
  usecase "Calculate Performance Metrics" as UC4
  usecase "Monitor Injury Status" as UC5
  usecase "Retrieve Medical Records" as UC6
  usecase "Create Training Plan" as UC7
  usecase "View Progress Report" as UC8
  usecase "Manage Nutrition Plan" as UC9
  usecase "Send Alert Notification" as UC10
  usecase "Assign Exercise Routine" as UC11
  usecase "Track Recovery Progress" as UC12
}

Athlete -- UC1
Athlete -- UC3
Athlete -- UC8
Athlete -- UC9

Coach -- UC1
Coach -- UC7
Coach -- UC8
Coach -- UC11

MedicalStaff -- UC5
MedicalStaff -- UC12

UC1 ..> UC2 : <<include>>
UC3 ..> UC4 : <<include>>
UC5 ..> UC6 : <<include>>

UC7 ..> UC11 : <<include>>
UC10 ..> UC5 : <<extend>>
@enduml