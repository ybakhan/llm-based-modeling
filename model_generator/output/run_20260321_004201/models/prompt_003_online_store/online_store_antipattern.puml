@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor Customer as A1
actor Admin as A2

rectangle "Online Store" {
  usecase "Browse Products" as UC1
  usecase "Place Order" as UC2
  usecase "Track Order" as UC3
  usecase "Manage Inventory" as UC4
  usecase "Validate Payment Details" as UC5
  usecase "View Sales Reports" as UC6
}

A1 -- UC1
A1 -- UC2
A1 -- UC3
A2 -- UC4
A2 -- UC6

UC2 ..> UC5 : <<include>>
@enduml