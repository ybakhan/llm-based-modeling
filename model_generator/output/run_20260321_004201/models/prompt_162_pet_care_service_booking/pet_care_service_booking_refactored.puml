@startuml
' Version 2 – refactored, no antipattern (Drop Functional Decomposition)

actor "Pet Owner" as PO
actor "Service Provider" as SP

rectangle "Pet Care Service Booking System" {
  usecase "Browse Services" as UC1
  usecase "Book Grooming Appointment" as UC2
  usecase "Cancel Booking" as UC4
  usecase "View Bookings" as UC5
  usecase "Manage Availability" as UC6
  usecase "Confirm Booking" as UC7
}

PO -- UC1
PO -- UC2
PO -- UC4
PO -- UC5
SP -- UC6
SP -- UC7

@enduml