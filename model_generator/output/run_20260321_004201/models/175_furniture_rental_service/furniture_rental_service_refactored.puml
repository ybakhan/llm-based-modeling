@startuml
' Version 2 – refactored, no antipattern (Drop Functional Decomposition)

actor "Customer" as Customer
actor "Warehouse Staff" as Staff

rectangle "Furniture Rental Service" {
  usecase "Browse Furniture Catalog" as UC1
  usecase "Place Rental Order" as UC3
  usecase "Return Furniture" as UC4
  usecase "Process Delivery" as UC5
}

Customer -- UC1
Customer -- UC3
Customer -- UC4
Staff -- UC5

@enduml