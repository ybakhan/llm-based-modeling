@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship
left to right direction

actor "Pharmacist" as Pharmacist
actor "Customer" as Customer
actor "Pharmacy Manager" as Manager

rectangle "Pharmacy Management System" {
    usecase "Fill Prescription" as UC1
    usecase "Verify Patient Insurance" as UC2
    usecase "Check Drug Interactions" as UC3
    usecase "Process Payment" as UC4
    usecase "Generate Receipt" as UC5
    usecase "Manage Inventory" as UC6
    usecase "Register Customer" as UC7
    usecase "View Prescription History" as UC8
    usecase "Order Medication Refill" as UC9
    usecase "Generate Sales Report" as UC10
    usecase "Manage Supplier Orders" as UC11
    usecase "Update Drug Catalog" as UC12
}

Pharmacist -- UC1
Pharmacist -- UC4
Pharmacist -- UC6
Pharmacist -- UC7
Customer -- UC8
Customer -- UC9
Manager -- UC10
Manager -- UC11
Manager -- UC12

UC1 ..> UC2 : <<include>>
UC1 ..> UC3 : <<include>>
UC4 ..> UC5 : <<include>>
UC9 ..> UC1 : <<include>>
@enduml