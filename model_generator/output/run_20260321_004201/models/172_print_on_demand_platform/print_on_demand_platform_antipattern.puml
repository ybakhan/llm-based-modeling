@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor Designer
actor Customer
actor "Production Staff" as PS
actor "Payment Gateway" as PG

rectangle "Print-on-Demand Platform" {
  usecase "Upload Design" as UC1
  usecase "Validate File Format" as UC2
  usecase "Browse Catalog" as UC3
  usecase "Customize Product" as UC4
  usecase "Place Order" as UC5
  usecase "Calculate Shipping Cost" as UC6
  usecase "Process Payment" as UC7
  usecase "Generate Invoice" as UC8
  usecase "Track Order" as UC9
  usecase "Fulfill Order" as UC10
  usecase "Manage Product Listings" as UC11
  usecase "View Sales Reports" as UC12
}

Designer -- UC1
Designer -- UC11
Designer -- UC12
Customer -- UC3
Customer -- UC4
Customer -- UC5
Customer -- UC7
Customer -- UC9
PS -- UC10
PG -- UC7

UC1 ..> UC2 : <<include>>
UC5 ..> UC6 : <<include>>
UC7 ..> UC8 : <<include>>
@enduml