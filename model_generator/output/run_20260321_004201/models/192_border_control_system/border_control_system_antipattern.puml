@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "Border Officer" as BO
actor "Traveler" as TR
actor "Immigration Supervisor" as IS
actor "Customs Officer" as CO

rectangle "Border Control System" {
  usecase "Verify Passport" as UC1
  usecase "Scan Passport Chip" as UC2
  usecase "Process Visa Application" as UC3
  usecase "Validate Supporting Documents" as UC4
  usecase "Conduct Secondary Screening" as UC5
  usecase "Perform Background Check" as UC6
  usecase "Record Entry/Exit" as UC7
  usecase "Submit Travel Declaration" as UC8
  usecase "Issue Entry Denial" as UC9
  usecase "Inspect Luggage" as UC10
  usecase "Generate Crossing Report" as UC11
  usecase "Flag Suspicious Traveler" as UC12
  usecase "Override Entry Decision" as UC13
}

BO -- UC1
BO -- UC5
BO -- UC7
BO -- UC9
BO -- UC12

TR -- UC8
TR -- UC3

IS -- UC11
IS -- UC13

CO -- UC10

UC1 ..> UC2 : <<include>>
UC3 ..> UC4 : <<include>>
UC5 ..> UC6 : <<include>>

UC9 ..> UC5 : <<extend>>
IS --|> BO

@enduml