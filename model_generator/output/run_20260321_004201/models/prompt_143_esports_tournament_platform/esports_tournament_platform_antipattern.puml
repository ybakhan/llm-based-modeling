@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

left to right direction

actor "Team Captain" as TC
actor "Tournament Admin" as TA
actor "Spectator" as SP
actor "Finance Manager" as FM

rectangle "Esports Tournament Platform" {
  usecase "Register Team" as UC1
  usecase "Validate Team Roster" as UC2
  usecase "Browse Tournaments" as UC3
  usecase "Join Tournament" as UC4
  usecase "Schedule Match" as UC5
  usecase "Assign Server Instance" as UC6
  usecase "Report Match Result" as UC7
  usecase "View Live Bracket" as UC8
  usecase "Watch Live Stream" as UC9
  usecase "Manage Tournament Settings" as UC10
  usecase "Process Prize Payout" as UC11
  usecase "Calculate Prize Split" as UC12
  usecase "View Match History" as UC13
  usecase "Submit Dispute" as UC14
}

TC -- UC1
TC -- UC3
TC -- UC4
TC -- UC7
TC -- UC13
TC -- UC14

TA -- UC5
TA -- UC10
TA -- UC7

SP -- UC8
SP -- UC9

FM -- UC11

UC1 ..> UC2 : <<include>>
UC5 ..> UC6 : <<include>>
UC11 ..> UC12 : <<include>>

@enduml