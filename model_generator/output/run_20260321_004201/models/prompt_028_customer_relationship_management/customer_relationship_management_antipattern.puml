@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship
left to right direction

actor "Sales Rep" as SalesRep
actor "Sales Manager" as SalesManager
actor "Support Agent" as SupportAgent
actor "Administrator" as Admin

rectangle "CRM System" {
  usecase "Manage Leads" as UC1
  usecase "Validate Lead Data" as UC2
  usecase "Log Customer Interaction" as UC3
  usecase "Record Timestamp" as UC4
  usecase "Manage Contacts" as UC5
  usecase "Track Opportunities" as UC6
  usecase "Generate Sales Report" as UC7
  usecase "Format Report Output" as UC8
  usecase "Schedule Follow-Up" as UC9
  usecase "Manage User Accounts" as UC10
  usecase "Export Contacts" as UC11
  usecase "View Dashboard" as UC12
}

SalesRep -- UC1
SalesRep -- UC3
SalesRep -- UC5
SalesRep -- UC6
SalesRep -- UC9
SalesRep -- UC11

SalesManager -- UC7
SalesManager -- UC12
SalesManager -- UC6

SupportAgent -- UC3
SupportAgent -- UC5

Admin -- UC10

UC1 ..> UC2 : <<include>>
UC3 ..> UC4 : <<include>>
UC7 ..> UC8 : <<include>>
@enduml