@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "Member" as Member
actor "Librarian" as Librarian
actor "Administrator" as Admin

rectangle "Library Management System" {
  usecase "Borrow Book" as UC1
  usecase "Return Book" as UC2
  usecase "Search Catalog" as UC3
  usecase "Reserve Book" as UC4
  usecase "Manage Members" as UC5
  usecase "Generate Reports" as UC6
  usecase "Pay Fine" as UC7
  usecase "Manage Book Inventory" as UC8
  usecase "View Borrowing History" as UC9
  usecase "Validate Library Card" as UC10
  usecase "Update Book Availability" as UC11
  usecase "Fetch Search Results" as UC12
  usecase "Notify Overdue" as UC13
}

Member -- UC1
Member -- UC2
Member -- UC3
Member -- UC4
Member -- UC7
Member -- UC9
Librarian -- UC1
Librarian -- UC2
Librarian -- UC5
Librarian -- UC13
Admin -- UC6
Admin -- UC8

UC1 ..> UC10 : <<include>>
UC2 ..> UC11 : <<include>>
UC3 ..> UC12 : <<include>>

UC7 ..> UC4 : <<extend>>
@enduml