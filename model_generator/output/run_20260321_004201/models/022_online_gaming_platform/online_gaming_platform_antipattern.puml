@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship
left to right direction

actor "Player" as Player
actor "Game Admin" as Admin

rectangle "Online Gaming Platform" {
  usecase "Join Match" as UC1
  usecase "Browse Games" as UC2
  usecase "Validate Player Credentials" as UC3
  usecase "Create Tournament" as UC4
  usecase "Chat with Players" as UC5
}

Player -- UC1
Player -- UC2
Player -- UC5
Admin -- UC4
UC1 ..> UC3 : <<include>>

@enduml