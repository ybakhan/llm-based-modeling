@startuml
' Version 2 – refactored, no antipattern (Drop Functional Decomposition)

actor Student
actor Instructor

rectangle "E-Learning Platform" {
  usecase "Browse Courses" as UC1
  usecase "Enroll in Course" as UC2
  usecase "Submit Quiz" as UC3
  usecase "Create Course" as UC5
  usecase "View Grades" as UC6
}

Student -- UC1
Student -- UC2
Student -- UC3
Student -- UC6
Instructor -- UC5

@enduml