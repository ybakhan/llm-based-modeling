@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "Job Seeker" as A1
actor "Employer" as A2
actor "Admin" as A3

rectangle "Job Portal" {
  usecase "Register Account" as UC1
  usecase "Search Jobs" as UC2
  usecase "Apply for Job" as UC3
  usecase "Post Job Listing" as UC4
  usecase "Filter Results" as UC5
  usecase "Manage Users" as UC6
  usecase "View Applications" as UC7
}

A1 -- UC1
A1 -- UC2
A1 -- UC3
A2 -- UC4
A2 -- UC7
A3 -- UC6

UC2 ..> UC5 : <<include>>
@enduml