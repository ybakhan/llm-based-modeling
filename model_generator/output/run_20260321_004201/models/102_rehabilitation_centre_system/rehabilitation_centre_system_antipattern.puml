@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "Therapist" as Therapist
actor "Patient" as Patient

rectangle "Rehabilitation Centre System" {
  usecase "Schedule Therapy Session" as UC1
  usecase "Check Therapist Availability" as UC2
  usecase "Record Progress Notes" as UC3
  usecase "View Treatment Plan" as UC4
  usecase "Register Patient" as UC5
}

Therapist -- UC1
Therapist -- UC3
Patient -- UC4
Patient -- UC5
UC1 ..> UC2 : <<include>>
@enduml