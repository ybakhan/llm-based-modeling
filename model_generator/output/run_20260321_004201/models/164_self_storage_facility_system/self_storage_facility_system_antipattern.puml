@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor Customer
actor Manager
actor "Payment Gateway" as PG

rectangle "Self-Storage Facility System" {
  usecase "Reserve Unit" as UC1
  usecase "Check Unit Availability" as UC2
  usecase "Process Payment" as UC3
  usecase "Validate Payment Details" as UC4
  usecase "View Unit Status" as UC5
  usecase "Manage Unit Inventory" as UC6
  usecase "Terminate Rental Agreement" as UC7
  usecase "Generate Final Invoice" as UC8
  usecase "Apply Late Fee" as UC9
  usecase "Access Unit" as UC10
  usecase "Update Customer Profile" as UC11
  usecase "Generate Occupancy Report" as UC12
  usecase "Sign Rental Agreement" as UC13
}

Customer -- UC1
Customer -- UC3
Customer -- UC10
Customer -- UC11
Customer -- UC13
Manager -- UC5
Manager -- UC6
Manager -- UC7
Manager -- UC12
PG -- UC3

UC1 ..> UC2 : <<include>>
UC3 ..> UC4 : <<include>>
UC7 ..> UC8 : <<include>>
UC9 ..> UC3 : <<extend>>
@enduml