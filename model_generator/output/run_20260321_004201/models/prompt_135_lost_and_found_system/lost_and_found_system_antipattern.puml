@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "User" as User
actor "Administrator" as Admin

rectangle "Lost and Found System" {
  usecase "Report Lost Item" as UC1
  usecase "Validate Item Details" as UC2
  usecase "Search Found Items" as UC3
  usecase "Register Found Item" as UC4
  usecase "Claim Item" as UC5
  usecase "Manage Inventory" as UC6
}

User -- UC1
User -- UC3
User -- UC5
Admin -- UC4
Admin -- UC6

UC1 ..> UC2 : <<include>>

@enduml