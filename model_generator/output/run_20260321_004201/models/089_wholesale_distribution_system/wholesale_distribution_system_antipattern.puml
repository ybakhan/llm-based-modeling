@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "Wholesale Buyer" as Buyer
actor "Warehouse Manager" as WM
actor "Sales Representative" as SR

rectangle "Wholesale Distribution System" {
  usecase "Place Bulk Order" as UC1
  usecase "Validate Inventory Availability" as UC2
  usecase "Track Order Status" as UC3
  usecase "Process Shipment" as UC4
  usecase "Generate Shipping Label" as UC5
  usecase "Manage Product Catalog" as UC6
  usecase "Register New Customer" as UC7
  usecase "Verify Business License" as UC8
  usecase "Apply Volume Discount" as UC9
  usecase "Generate Sales Report" as UC10
  usecase "Process Return" as UC11
  usecase "Manage Warehouse Inventory" as UC12
}

Buyer -- UC1
Buyer -- UC3
Buyer -- UC11

WM -- UC4
WM -- UC12

SR -- UC6
SR -- UC7
SR -- UC10

UC1 ..> UC2 : <<include>>
UC4 ..> UC5 : <<include>>
UC7 ..> UC8 : <<include>>

UC9 ..> UC1 : <<extend>>

@enduml