@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "League Administrator" as Admin
actor "Team Manager" as TM
actor "Referee" as Ref
actor "Fan" as Fan

rectangle "Sports League Management System" {
  usecase "Register Team" as UC1
  usecase "Validate Team Roster" as UC1a
  usecase "Schedule Match" as UC2
  usecase "Check Venue Availability" as UC2a
  usecase "Record Match Result" as UC3
  usecase "Calculate Updated Standings" as UC3a
  usecase "Manage Player Transfers" as UC4
  usecase "View League Standings" as UC5
  usecase "Assign Referee to Match" as UC6
  usecase "Submit Match Report" as UC7
  usecase "View Match Schedule" as UC8
  usecase "Manage Season" as UC9
  usecase "Register Player" as UC10
  usecase "Process Disciplinary Action" as UC11
}

Admin -- UC1
Admin -- UC2
Admin -- UC3
Admin -- UC6
Admin -- UC9
Admin -- UC11
TM -- UC4
TM -- UC10
TM -- UC8
Ref -- UC7
Ref -- UC8
Fan -- UC5
Fan -- UC8

UC1 ..> UC1a : <<include>>
UC2 ..> UC2a : <<include>>
UC3 ..> UC3a : <<include>>

@enduml