@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "End User" as EU
actor "Meteorologist" as MET
actor "System Administrator" as SA

rectangle "Weather Forecasting Service" {
  usecase "View Weather Forecast" as UC1
  usecase "Fetch Forecast Data" as UC2
  usecase "Set Location Preferences" as UC3
  usecase "Publish Forecast" as UC4
  usecase "Manage Weather Stations" as UC5
  usecase "Subscribe to Alerts" as UC6
  usecase "Configure Alert Thresholds" as UC7
}

EU -- UC1
UC1 ..> UC2 : <<include>>
EU -- UC3
EU -- UC6
MET -- UC4
SA -- UC5
UC7 ..|> UC6 : <<extend>>

@enduml