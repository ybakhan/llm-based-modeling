@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship
left to right direction

actor "License Admin" as Admin
actor "Compliance Officer" as Officer
actor "End User" as EndUser
actor "Notification Service" as NotifSvc

rectangle "Software License Management System" {
  usecase "Register Software Product" as UC1
  usecase "Assign License" as UC2
  usecase "Validate User Eligibility" as UC3
  usecase "Revoke License" as UC4
  usecase "Renew License" as UC5
  usecase "Process Payment" as UC6
  usecase "View Assigned Licenses" as UC7
  usecase "Request License" as UC8
  usecase "Generate Compliance Report" as UC9
  usecase "Collect License Data" as UC10
  usecase "Notify Expiring Licenses" as UC11
  usecase "Track License Usage" as UC12
}

Admin -- UC1
Admin -- UC2
Admin -- UC4
Admin -- UC5
Admin -- UC12

EndUser -- UC7
EndUser -- UC8

Officer -- UC9

NotifSvc -- UC11

UC2 ..> UC3 : <<include>>
UC5 ..> UC6 : <<include>>
UC9 ..> UC10 : <<include>>
UC11 ..> UC5 : <<extend>>
@enduml