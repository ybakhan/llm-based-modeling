@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship
left to right direction

actor "Veterinarian" as Vet
actor "Receptionist" as Recep
actor "Pet Owner" as Owner

rectangle "Veterinary Clinic System" {
    usecase "Register Pet" as UC1
    usecase "Schedule Appointment" as UC2
    usecase "Conduct Examination" as UC3
    usecase "Check Vital Signs" as UC4
    usecase "Prescribe Medication" as UC5
    usecase "View Medical Records" as UC6
    usecase "Process Payment" as UC7
    usecase "Generate Invoice" as UC8
    usecase "Manage Vaccinations" as UC9
    usecase "Cancel Appointment" as UC10
}

Owner -- UC1
Owner -- UC2
Owner -- UC6
Owner -- UC10
Recep -- UC2
Recep -- UC7
Recep -- UC1
Vet -- UC3
Vet -- UC9
Vet -- UC6

UC3 ..> UC4 : <<include>>
UC3 ..> UC5 : <<include>>
UC7 ..> UC8 : <<include>>
@enduml