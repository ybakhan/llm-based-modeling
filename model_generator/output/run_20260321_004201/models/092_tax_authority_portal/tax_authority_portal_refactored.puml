@startuml
' Version 2 – refactored, no antipattern (Drop Functional Decomposition)
left to right direction

actor "Taxpayer" as Taxpayer
actor "Tax Officer" as TaxOfficer
actor "Auditor" as Auditor
actor "System Administrator" as SysAdmin

rectangle "Tax Authority Portal" {
  usecase "Register Taxpayer Account" as UC1
  usecase "File Tax Return" as UC3
  usecase "View Tax History" as UC5
  usecase "Make Tax Payment" as UC6
  usecase "Process Refund" as UC7
  usecase "Conduct Tax Audit" as UC9
  usecase "Generate Audit Report" as UC10
  usecase "Send Tax Notice" as UC11
  usecase "Manage User Accounts" as UC12
  usecase "Appeal Tax Assessment" as UC13
  usecase "Download Tax Certificate" as UC14
  usecase "Schedule Appointment" as UC15
  usecase "Update Tax Rates" as UC16
}

Taxpayer -- UC1
Taxpayer -- UC3
Taxpayer -- UC5
Taxpayer -- UC6
Taxpayer -- UC13
Taxpayer -- UC14
Taxpayer -- UC15

TaxOfficer -- UC7
TaxOfficer -- UC11
TaxOfficer -- UC9

Auditor -- UC9
Auditor -- UC10

SysAdmin -- UC12
SysAdmin -- UC16
@enduml