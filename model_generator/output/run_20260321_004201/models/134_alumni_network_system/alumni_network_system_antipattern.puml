@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "Alumni" as A1
actor "Admin" as A2

rectangle "Alumni Network System" {
  usecase "Search Alumni Directory" as UC1
  usecase "Update Profile" as UC2
  usecase "Register for Event" as UC3
  usecase "Manage Events" as UC4
  usecase "Validate Profile Fields" as UC5
}

A1 -- UC1
A1 -- UC2
A1 -- UC3
A2 -- UC4

UC2 ..> UC5 : <<include>>

@enduml