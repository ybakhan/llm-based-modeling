@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship
left to right direction

actor "Customer" as Customer
actor "Travel Agent" as Agent
actor "Payment Gateway" as Gateway

rectangle "Tour Package Booking System" {
  usecase "Search Tour Packages" as UC1
  usecase "Apply Search Filters" as UC2
  usecase "View Package Details" as UC3
  usecase "Book Tour Package" as UC4
  usecase "Validate Payment Details" as UC5
  usecase "Cancel Booking" as UC6
  usecase "Generate Cancellation Reference" as UC7
  usecase "View Booking History" as UC8
  usecase "Manage Tour Packages" as UC9
  usecase "Process Refund" as UC10
  usecase "Leave Review" as UC11
  usecase "Apply Discount Code" as UC12
}

Customer -- UC1
Customer -- UC3
Customer -- UC4
Customer -- UC6
Customer -- UC8
Customer -- UC11

Agent -- UC9
Agent -- UC10

Gateway -- UC4

UC1 ..> UC2 : <<include>>
UC4 ..> UC5 : <<include>>
UC6 ..> UC7 : <<include>>
UC4 ..> UC12 : <<extend>>

@enduml