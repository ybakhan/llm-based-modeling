@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "Project Creator" as Creator
actor "Backer" as Backer
actor "Administrator" as Admin
actor "Payment Gateway" as PG

rectangle "Crowdfunding Platform" {
  usecase "Create Campaign" as UC1
  usecase "Upload Campaign Media" as UC2
  usecase "Manage Campaign Updates" as UC3
  usecase "Withdraw Funds" as UC4
  usecase "Validate Bank Account" as UC5
  usecase "Browse Campaigns" as UC6
  usecase "Back Project" as UC7
  usecase "Process Payment Details" as UC8
  usecase "Track Pledges" as UC9
  usecase "Review Flagged Campaigns" as UC10
  usecase "Generate Platform Reports" as UC11
  usecase "Authorize Transaction" as UC12
}

Creator -- UC1
Creator -- UC3
Creator -- UC4
Backer -- UC6
Backer -- UC7
Backer -- UC9
Admin -- UC10
Admin -- UC11
PG -- UC12

UC1 ..> UC2 : <<include>>
UC7 ..> UC8 : <<include>>
UC4 ..> UC5 : <<include>>
UC7 ..> UC12 : <<include>>
@enduml