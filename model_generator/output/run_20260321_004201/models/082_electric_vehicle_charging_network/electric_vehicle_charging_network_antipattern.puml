@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "EV Driver" as Driver
actor "Network Operator" as Operator

rectangle "Electric Vehicle Charging Network" {
  usecase "Start Charging Session" as UC1
  usecase "Authenticate RFID Card" as UC2
  usecase "View Charging Status" as UC3
  usecase "Process Payment" as UC4
  usecase "Monitor Station Health" as UC5
  usecase "View Usage Reports" as UC6
}

Driver -- UC1
Driver -- UC3
Driver -- UC4
UC1 ..> UC2 : <<include>>
Operator -- UC5
Operator -- UC6

@enduml