@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "Adopter" as Adopter
actor "Shelter Staff" as Staff
actor "Veterinarian" as Vet
actor "Administrator" as Admin

rectangle "Pet Adoption System" {
  usecase "Browse Available Pets" as UC1
  usecase "Search Pets by Criteria" as UC2
  usecase "View Pet Profile" as UC3
  usecase "Submit Adoption Application" as UC4
  usecase "Validate Applicant Address" as UC5
  usecase "Review Application" as UC6
  usecase "Schedule Home Visit" as UC7
  usecase "Check Availability Slot" as UC8
  usecase "Process Adoption Fee" as UC9
  usecase "Generate Payment Receipt" as UC10
  usecase "Register New Pet" as UC11
  usecase "Update Pet Medical Records" as UC12
  usecase "Perform Health Checkup" as UC13
  usecase "Manage User Accounts" as UC14
  usecase "Generate Adoption Reports" as UC15
}

Adopter -- UC1
Adopter -- UC2
Adopter -- UC3
Adopter -- UC4
Adopter -- UC9
Staff -- UC6
Staff -- UC7
Staff -- UC11
Vet -- UC12
Vet -- UC13
Admin -- UC14
Admin -- UC15

UC4 ..> UC5 : <<include>>
UC7 ..> UC8 : <<include>>
UC9 ..> UC10 : <<include>>

UC1 <.. UC2 : <<extend>>

@enduml