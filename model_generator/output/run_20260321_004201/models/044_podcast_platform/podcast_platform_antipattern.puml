@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor Listener
actor Podcaster
actor Admin

rectangle "Podcast Platform" {
  usecase "Browse Catalog" as UC1
  usecase "Search Podcasts" as UC2
  usecase "Parse Search Query" as UC3
  usecase "Play Episode" as UC4
  usecase "Subscribe to Podcast" as UC5
  usecase "Update Subscription List" as UC6
  usecase "Rate and Review" as UC7
  usecase "Download Episode" as UC8
  usecase "Publish Episode" as UC9
  usecase "Validate Audio File" as UC10
  usecase "Manage Podcast Profile" as UC11
  usecase "View Analytics" as UC12
  usecase "Moderate Content" as UC13
  usecase "Manage Users" as UC14
}

Listener -- UC1
Listener -- UC2
Listener -- UC4
Listener -- UC5
Listener -- UC7
Listener -- UC8

Podcaster -- UC9
Podcaster -- UC11
Podcaster -- UC12

Admin -- UC13
Admin -- UC14

UC2 ..> UC3 : <<include>>
UC9 ..> UC10 : <<include>>
UC5 ..> UC6 : <<include>>

@enduml