@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "Clerk" as Clerk
actor "Judge" as Judge
actor "Attorney" as Attorney
actor "Administrator" as Admin

rectangle "Court Case Management System" {
  usecase "File New Case" as UC1
  usecase "Validate Case Details" as UC2
  usecase "Assign Judge to Case" as UC3
  usecase "Schedule Hearing" as UC4
  usecase "Check Court Availability" as UC5
  usecase "Record Hearing Outcome" as UC6
  usecase "Issue Court Order" as UC7
  usecase "Generate Order Document" as UC8
  usecase "View Case History" as UC9
  usecase "Submit Evidence" as UC10
  usecase "Manage User Accounts" as UC11
  usecase "Generate Case Report" as UC12
  usecase "Request Adjournment" as UC13
}

Clerk -- UC1
Clerk -- UC3
Clerk -- UC4
Clerk -- UC9
Clerk -- UC12

Judge -- UC6
Judge -- UC7
Judge -- UC9

Attorney -- UC10
Attorney -- UC9
Attorney -- UC13

Admin -- UC11

UC1 ..> UC2 : <<include>>
UC4 ..> UC5 : <<include>>
UC7 ..> UC8 : <<include>>

UC4 ..> UC13 : <<extend>>

@enduml