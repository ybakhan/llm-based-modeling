@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "Rider" as Rider
actor "Driver" as Driver

rectangle "Ride Sharing Service" {
  usecase "Request Ride" as UC1
  usecase "Calculate Fare" as UC2
  usecase "Accept Ride" as UC3
  usecase "Rate Driver" as UC4
  usecase "View Ride History" as UC5
  usecase "Update Location" as UC6
}

Rider -- UC1
Rider -- UC4
Rider -- UC5
Driver -- UC3
Driver -- UC6
UC1 ..> UC2 : <<include>>

@enduml