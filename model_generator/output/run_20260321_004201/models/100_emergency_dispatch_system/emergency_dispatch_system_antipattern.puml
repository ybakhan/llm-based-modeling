@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "Caller" as Caller
actor "Dispatcher" as Dispatcher
actor "Field Unit" as FieldUnit

rectangle "Emergency Dispatch System" {
  usecase "Report Emergency" as UC1
  usecase "Receive Emergency Call" as UC2
  usecase "Dispatch Emergency Unit" as UC3
  usecase "Determine Unit Availability" as UC4
  usecase "Log Incident" as UC5
  usecase "Update Incident Status" as UC6
}

Caller -- UC1
Dispatcher -- UC2
Dispatcher -- UC3
UC3 ..> UC4 : <<include>>
Dispatcher -- UC5
FieldUnit -- UC6

@enduml