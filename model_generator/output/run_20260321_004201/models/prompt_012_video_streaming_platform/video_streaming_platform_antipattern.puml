@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor Viewer
actor "Content Creator" as Creator
actor Administrator

rectangle "Video Streaming Platform" {
  usecase "Register Account" as UC1
  usecase "Search Content" as UC2
  usecase "Fetch Search Results" as UC3
  usecase "Play Video" as UC4
  usecase "Load Video Stream" as UC5
  usecase "Rate Video" as UC6
  usecase "Create Playlist" as UC7
  usecase "Validate Playlist Name" as UC8
  usecase "Upload Video" as UC9
  usecase "Manage Subscriptions" as UC10
  usecase "Moderate Content" as UC11
  usecase "View Watch History" as UC12
  usecase "Add Subtitles" as UC13
}

Viewer -- UC1
Viewer -- UC2
Viewer -- UC4
Viewer -- UC6
Viewer -- UC7
Viewer -- UC10
Viewer -- UC12
Creator -- UC9
Creator -- UC13
Administrator -- UC11

UC2 ..> UC3 : <<include>>
UC4 ..> UC5 : <<include>>
UC7 ..> UC8 : <<include>>

@enduml