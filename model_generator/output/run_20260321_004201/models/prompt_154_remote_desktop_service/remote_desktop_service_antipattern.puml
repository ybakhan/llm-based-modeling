@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship
left to right direction

actor "End User" as EU
actor "IT Administrator" as Admin

rectangle "Remote Desktop Service" {
  usecase "Connect to Remote Desktop" as UC1
  usecase "Establish VPN Tunnel" as UC2
  usecase "Transfer Files" as UC3
  usecase "Manage User Sessions" as UC4
  usecase "View Session Logs" as UC5
  usecase "Disconnect Session" as UC6
}

EU -- UC1
EU -- UC3
EU -- UC6
Admin -- UC4
Admin -- UC5

UC1 ..> UC2 : <<include>>
@enduml