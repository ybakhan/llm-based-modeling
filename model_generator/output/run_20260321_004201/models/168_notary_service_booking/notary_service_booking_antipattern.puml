@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "Client" as Client
actor "Notary" as Notary

rectangle "Notary Service Booking System" {
  usecase "Book Appointment" as UC1
  usecase "Validate Available Time Slots" as UC2
  usecase "Cancel Appointment" as UC3
  usecase "View Upcoming Appointments" as UC4
  usecase "Upload Documents" as UC5
  usecase "Review Client Documents" as UC6
}

Client -- UC1
UC1 ..> UC2 : <<include>>
Client -- UC3
Client -- UC4
Client -- UC5
Notary -- UC4
Notary -- UC6

@enduml