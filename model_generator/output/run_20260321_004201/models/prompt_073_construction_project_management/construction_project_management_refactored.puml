@startuml
' Version 2 – refactored, no antipattern (Drop Functional Decomposition)

actor "Project Manager" as PM
actor "Inspector" as Inspector
actor "Contractor" as Contractor

rectangle "Construction Project Management System" {
  usecase "Create Project Schedule" as UC1
  usecase "Assign Subcontractor" as UC2
  usecase "Submit Inspection Request" as UC3
  usecase "Log Daily Progress" as UC5
  usecase "Review Budget" as UC6
}

PM -- UC1
PM -- UC2
PM -- UC6
Inspector -- UC3
Contractor -- UC5

@enduml