@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "Rider" as Rider
actor "Admin" as Admin
actor "Payment Gateway" as PG

rectangle "Bike Sharing System" {
  usecase "Register Account" as UC1
  usecase "Rent Bike" as UC2
  usecase "Verify Membership Status" as UC3
  usecase "Return Bike" as UC4
  usecase "Calculate Ride Duration" as UC5
  usecase "Process Payment" as UC6
  usecase "Validate Payment Details" as UC7
  usecase "View Ride History" as UC8
  usecase "Report Bike Issue" as UC9
  usecase "Manage Stations" as UC10
  usecase "Monitor Fleet" as UC11
  usecase "View Station Map" as UC12
}

Rider -- UC1
Rider -- UC2
Rider -- UC4
Rider -- UC6
Rider -- UC8
Rider -- UC9
Rider -- UC12

Admin -- UC10
Admin -- UC11

PG -- UC6

UC2 ..> UC3 : <<include>>
UC4 ..> UC5 : <<include>>
UC6 ..> UC7 : <<include>>

@enduml