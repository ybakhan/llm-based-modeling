@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship
left to right direction

actor "Client" as Client
actor "Notary" as Notary

rectangle "Notary Service Booking System" {
  usecase "Book Appointment" as UC1
  usecase "Select Time Slot" as UC2
  usecase "Cancel Appointment" as UC3
  usecase "View Appointments" as UC4
  usecase "Upload Documents" as UC5
  usecase "Confirm Appointment" as UC6
  usecase "View Client Documents" as UC7
}

Client -- UC1
UC1 ..> UC2 : <<include>>
Client -- UC3
Client -- UC4
Client -- UC5
Notary -- UC4
Notary -- UC6
Notary -- UC7
@enduml