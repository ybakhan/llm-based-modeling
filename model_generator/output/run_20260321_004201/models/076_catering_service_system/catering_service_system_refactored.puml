@startuml
' Version 2 – refactored, no antipattern (Drop Functional Decomposition)

actor "Customer" as Customer
actor "Chef" as Chef
actor "Event Coordinator" as EC
actor "Payment Gateway" as PG

rectangle "Catering Service System" {
  usecase "Browse Menu" as UC1
  usecase "Place Catering Order" as UC2
  usecase "Process Payment" as UC3
  usecase "Track Order Status" as UC4
  usecase "Create Menu Package" as UC5
  usecase "Manage Event Schedule" as UC6
  usecase "Generate Invoice" as UC7
  usecase "Request Custom Menu" as UC11
  usecase "Rate Service" as UC12
}

Customer -- UC1
Customer -- UC2
Customer -- UC3
Customer -- UC4
Customer -- UC11
Customer -- UC12
Chef -- UC5
EC -- UC6
EC -- UC7
PG -- UC3

@enduml