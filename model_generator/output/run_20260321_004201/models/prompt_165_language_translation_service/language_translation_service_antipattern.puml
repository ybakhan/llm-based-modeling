@startuml
' Version 1 – contains Functional Decomposition: Using the include relationship

actor "Customer" as Customer
actor "Professional Translator" as Translator
actor "Administrator" as Admin

rectangle "Language Translation Service" {
  usecase "Register Account" as UC1
  usecase "Submit Translation Request" as UC2
  usecase "Parse Source Text" as UC3
  usecase "Select Target Language" as UC4
  usecase "Translate Document" as UC5
  usecase "Apply Grammar Rules" as UC6
  usecase "Review Translation" as UC7
  usecase "Download Translated File" as UC8
  usecase "Format Output File" as UC9
  usecase "Rate Translation Quality" as UC10
  usecase "Manage Translator Profiles" as UC11
  usecase "View Translation History" as UC12
  usecase "Request Human Review" as UC13
  usecase "Manage Supported Languages" as UC14
}

Customer -- UC1
Customer -- UC2
Customer -- UC4
Customer -- UC8
Customer -- UC10
Customer -- UC12
Customer -- UC13

Translator -- UC5
Translator -- UC7

Admin -- UC11
Admin -- UC14

UC2 ..> UC3 : <<include>>
UC5 ..> UC6 : <<include>>
UC8 ..> UC9 : <<include>>

UC13 ..> UC7 : <<include>>

@enduml