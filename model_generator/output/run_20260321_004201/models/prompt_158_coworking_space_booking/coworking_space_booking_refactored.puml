actor "Member" as Member
actor "Administrator" as Admin

rectangle "Coworking Space Booking System" {
  usecase "Browse Spaces" as UC1
  usecase "Book Workspace" as UC2
  usecase "Cancel Booking" as UC4
  usecase "Manage Spaces" as UC5
  usecase "View Bookings" as UC6
