# ── Authentication ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Paths ──────────────────────────────────────────────────────────────────────
PLANTUML_JAR=/path/to/plantuml.jar
CONFIG=antipattern_config.yaml
OUTPUT_DIR=output

# ── Run parameters ─────────────────────────────────────────────────────────────
NUM_PROMPTS=10
# Allowed values: small  medium  large  (space-separated, e.g. "small medium")
SIZES=small
TASK_MODE=detect
# TASK_MODE=detect-and-refactor

# ── Output format ──────────────────────────────────────────────────────────────
# Set to --png to output PNG instead of JPEG; leave blank for JPEG (default)
PNG_FLAG=

# ── Rate limiting & reproducibility ────────────────────────────────────────────
RATE_LIMIT=2.5
# SEED=42